<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>InAmigos NGO</title>

  <!-- GOOGLE FONTS -->

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">

  <style>

    :root{
      --primary:#00b894;
      --secondary:#0f172a;
      --light:#f8fafc;
      --white:#ffffff;
      --gray:#64748b;
      --glass:rgba(255,255,255,0.12);
    }

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      scroll-behavior:smooth;
    }

    body{
      font-family:'Poppins',sans-serif;
      background:var(--light);
      color:#111827;
      overflow-x:hidden;
    }

    /* SCROLLBAR */

    ::-webkit-scrollbar{
      width:10px;
    }

    ::-webkit-scrollbar-thumb{
      background:var(--primary);
      border-radius:20px;
    }

    /* NAVBAR */

    nav{
      position:fixed;
      width:100%;
      top:0;
      left:0;
      z-index:1000;

      display:flex;
      justify-content:space-between;
      align-items:center;

      padding:18px 8%;

      backdrop-filter:blur(12px);
      background:rgba(15,23,42,0.65);

      border-bottom:1px solid rgba(255,255,255,0.1);
    }

    .logo{
      font-family:'Space Grotesk',sans-serif;
      font-size:30px;
      font-weight:700;
      color:white;
      letter-spacing:1px;
    }

    nav ul{
      display:flex;
      list-style:none;
      gap:30px;
    }

    nav ul li a{
      text-decoration:none;
      color:white;
      font-size:15px;
      font-weight:500;
      transition:0.3s;
      position:relative;
    }

    nav ul li a::after{
      content:'';
      position:absolute;
      width:0%;
      height:2px;
      background:var(--primary);
      left:0;
      bottom:-5px;
      transition:0.3s;
    }

    nav ul li a:hover::after{
      width:100%;
    }

    /* HERO */

    .hero{
      min-height:100vh;

      background:
      linear-gradient(rgba(15,23,42,0.75),rgba(15,23,42,0.75)),
      url('https://images.unsplash.com/photo-1529156069898-49953e39b3ac?auto=format&fit=crop&w=1500&q=80');

      background-size:cover;
      background-position:center;

      display:flex;
      align-items:center;
      justify-content:center;
      text-align:center;

      padding:20px;
      position:relative;
    }

    .hero::before{
      content:'';
      position:absolute;
      width:500px;
      height:500px;
      background:rgba(0,184,148,0.15);
      filter:blur(120px);
      border-radius:50%;
      top:10%;
      left:-10%;
    }

    .hero-content{
      max-width:900px;
      z-index:2;
      animation:fadeUp 1s ease;
    }

    .hero-content h1{
      font-family:'Playfair Display',serif;
      font-size:78px;
      line-height:1.1;
      color:white;
      margin-bottom:25px;
    }

    .hero-content p{
      color:#e2e8f0;
      font-size:20px;
      line-height:1.8;
      margin-bottom:40px;
    }

    .hero-btn{
      display:inline-block;
      padding:16px 38px;
      background:var(--primary);
      color:white;
      text-decoration:none;
      border-radius:60px;
      font-weight:600;
      transition:0.4s;
      box-shadow:0 10px 30px rgba(0,184,148,0.3);
    }

    .hero-btn:hover{
      transform:translateY(-5px);
      background:#019875;
    }

    /* GENERAL */

    section{
      padding:110px 8%;
    }

    .section-title{
      text-align:center;
      margin-bottom:70px;
    }

    .section-title h2{
      font-family:'Playfair Display',serif;
      font-size:52px;
      margin-bottom:12px;
      color:var(--secondary);
    }

    .section-title p{
      color:var(--gray);
      font-size:18px;
    }

    /* ABOUT */

    .about-container{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
      gap:60px;
      align-items:center;
    }

    .about-img{
      position:relative;
    }

    .about-img img{
      width:100%;
      border-radius:30px;
      box-shadow:0 20px 50px rgba(0,0,0,0.15);
    }

    .about-card{
      background:white;
      padding:40px;
      border-radius:25px;
      box-shadow:0 10px 40px rgba(0,0,0,0.08);
    }

    .about-card h3{
      font-size:36px;
      margin-bottom:20px;
      color:var(--primary);
      font-family:'Space Grotesk',sans-serif;
    }

    .about-card p{
      color:#475569;
      margin-bottom:18px;
      line-height:1.9;
    }

    /* PROJECTS */

    .projects{
      background:#ffffff;
    }

    .project-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
      gap:35px;
    }

    .project-card{
      background:white;
      border-radius:30px;
      overflow:hidden;
      transition:0.4s;
      box-shadow:0 10px 35px rgba(0,0,0,0.07);
    }

    .project-card:hover{
      transform:translateY(-12px);
    }

    .project-card img{
      width:100%;
      height:250px;
      object-fit:cover;
    }

    .project-content{
      padding:30px;
    }

    .project-content h3{
      margin-bottom:15px;
      color:var(--secondary);
      font-size:24px;
      font-family:'Space Grotesk',sans-serif;
    }

    .project-content p{
      color:#64748b;
      line-height:1.8;
    }

    /* IMPACT */

    .impact{
      background:
      linear-gradient(135deg,#0f172a,#111827);

      color:white;
      position:relative;
      overflow:hidden;
    }

    .impact::before{
      content:'';
      position:absolute;
      width:400px;
      height:400px;
      background:rgba(0,184,148,0.12);
      border-radius:50%;
      filter:blur(100px);
      right:-10%;
      top:20%;
    }

    .impact-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
      gap:30px;
      margin-top:50px;
      position:relative;
      z-index:2;
    }

    .impact-box{
      background:var(--glass);
      backdrop-filter:blur(15px);

      border:1px solid rgba(255,255,255,0.08);

      padding:45px 25px;
      text-align:center;
      border-radius:25px;
    }

    .impact-box h3{
      font-size:54px;
      margin-bottom:10px;
      color:var(--primary);
      font-family:'Space Grotesk',sans-serif;
    }

    .impact-box p{
      color:#e2e8f0;
    }

    /* JOIN */

    .join-wrapper{
      background:white;
      border-radius:35px;
      padding:80px 50px;
      text-align:center;

      box-shadow:0 15px 40px rgba(0,0,0,0.08);
    }

    .join-wrapper h2{
      font-size:55px;
      margin-bottom:20px;
      font-family:'Playfair Display',serif;
      color:var(--secondary);
    }

    .join-wrapper p{
      max-width:800px;
      margin:auto;
      color:#64748b;
      margin-bottom:35px;
      line-height:1.9;
    }

    /* CONTACT */

    .contact-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
      gap:30px;
    }

    .contact-card{
      background:white;
      border-radius:28px;
      padding:40px;
      text-align:center;

      box-shadow:0 10px 35px rgba(0,0,0,0.08);

      transition:0.4s;
    }

    .contact-card:hover{
      transform:translateY(-10px);
    }

    .contact-card h3{
      margin-bottom:15px;
      color:var(--primary);
      font-size:28px;
      font-family:'Space Grotesk',sans-serif;
    }

    .contact-card p{
      color:#64748b;
      margin-bottom:20px;
    }

    .contact-card a{
      text-decoration:none;
      color:var(--secondary);
      font-weight:600;
    }

    /* FORM */

    .form-box{
      background:white;
      margin-top:60px;
      padding:50px;
      border-radius:30px;
      box-shadow:0 10px 40px rgba(0,0,0,0.08);
    }

    .form-box h2{
      margin-bottom:30px;
      color:var(--secondary);
      font-size:40px;
      font-family:'Playfair Display',serif;
    }

    form{
      display:flex;
      flex-direction:column;
      gap:22px;
    }

    input,
    textarea{
      padding:18px;
      border:none;
      background:#f1f5f9;
      border-radius:15px;
      font-size:16px;
      font-family:'Poppins',sans-serif;
      outline:none;
    }

    textarea{
      height:160px;
      resize:none;
    }

    button{
      padding:16px;
      border:none;
      background:var(--primary);
      color:white;
      border-radius:15px;
      font-size:16px;
      cursor:pointer;
      transition:0.3s;
      font-weight:600;
    }

    button:hover{
      background:#019875;
    }

    /* FOOTER */

    footer{
      background:#020617;
      color:#cbd5e1;
      text-align:center;
      padding:45px 20px;
    }

    footer h2{
      margin-bottom:15px;
      font-family:'Space Grotesk',sans-serif;
      color:white;
    }

    footer a{
      color:var(--primary);
      text-decoration:none;
    }

    /* ANIMATION */

    @keyframes fadeUp{

      from{
        opacity:0;
        transform:translateY(40px);
      }

      to{
        opacity:1;
        transform:translateY(0);
      }

    }

    /* RESPONSIVE */

    @media(max-width:768px){

      nav{
        flex-direction:column;
        gap:18px;
      }

      nav ul{
        flex-wrap:wrap;
        justify-content:center;
        gap:18px;
      }

      .hero-content h1{
        font-size:44px;
      }

      .hero-content p{
        font-size:17px;
      }

      .section-title h2{
        font-size:36px;
      }

      .join-wrapper h2{
        font-size:38px;
      }

      .form-box{
        padding:30px;
      }

    }

  </style>

</head>

<body>

  <!-- NAVBAR -->

  <nav>

    <div class="logo">#InAmigos</div>

    <ul>
      <li><a href="#home">Home</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#projects">Projects</a></li>
      <li><a href="#impact">Impact</a></li>
      <li><a href="#join">Join</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>

  </nav>

  <!-- HERO -->

  <section class="hero" id="home">

    <div class="hero-content">

      <h1>
        Creating Hope Through Action & Awareness
      </h1>

      <p>
        InAmigos empowers communities through education,
        volunteering, environmental initiatives,
        and impactful social campaigns driven by passionate youth.
      </p>

      <a href="#join" class="hero-btn">
        Become A Volunteer
      </a>

    </div>

  </section>

  <!-- ABOUT -->

  <section id="about">

    <div class="section-title">

      <h2>About Our NGO</h2>

      <p>
        Together we inspire communities and create positive impact
      </p>

    </div>

    <div class="about-container">

      <div class="about-img">

        <img src="https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?auto=format&fit=crop&w=1200&q=80">

      </div>

      <div class="about-card">

        <h3>Who We Are</h3>

        <p>
          InAmigos is a youth-driven NGO dedicated to empowering lives
          through awareness campaigns, volunteering programs,
          and educational support.
        </p>

        <p>
          Our initiatives focus on community welfare,
          sustainability, and inspiring young individuals
          to become changemakers.
        </p>

        <p>
          We believe every small effort can transform lives
          and contribute toward a better future.
        </p>

      </div>

    </div>

  </section>

  <!-- PROJECTS -->

  <section class="projects" id="projects">

    <div class="section-title">

      <h2>Our Projects</h2>

      <p>
        Building impact through meaningful initiatives
      </p>

    </div>

    <div class="project-grid">

      <div class="project-card">

        <img src="https://images.unsplash.com/photo-1513258496099-48168024aec0?auto=format&fit=crop&w=1200&q=80">

        <div class="project-content">

          <h3>Education Support</h3>

          <p>
            Helping underprivileged children through mentorship,
            study resources, and learning opportunities.
          </p>

        </div>

      </div>

      <div class="project-card">

        <img src="https://images.unsplash.com/photo-1497493292307-31c376b6e479?auto=format&fit=crop&w=1200&q=80">

        <div class="project-content">

          <h3>Environment Drives</h3>

          <p>
            Promoting sustainability through plantation campaigns,
            awareness drives, and eco-friendly initiatives.
          </p>

        </div>

      </div>

      <div class="project-card">

        <img src="https://images.unsplash.com/photo-1521791136064-7986c2920216?auto=format&fit=crop&w=1200&q=80">

        <div class="project-content">

          <h3>Youth Volunteering</h3>

          <p>
            Encouraging students and young leaders
            to actively participate in community service.
          </p>

        </div>

      </div>

    </div>

  </section>

  <!-- IMPACT -->

  <section class="impact" id="impact">

    <div class="section-title">

      <h2 style="color:white;">Our Impact</h2>

      <p style="color:#cbd5e1;">
        Real change begins with collective action
      </p>

    </div>

    <div class="impact-grid">

      <div class="impact-box">

        <h3>5000+</h3>

        <p>Lives Impacted</p>

      </div>

      <div class="impact-box">

        <h3>120+</h3>

        <p>Active Volunteers</p>

      </div>

      <div class="impact-box">

        <h3>35+</h3>

        <p>Campaigns Conducted</p>

      </div>

      <div class="impact-box">

        <h3>20+</h3>

        <p>Community Projects</p>

      </div>

    </div>

  </section>

  <!-- JOIN -->

  <section id="join">

    <div class="join-wrapper">

      <h2>Join Our Mission</h2>

      <p>
        Become a part of a passionate community
        dedicated to making society more aware,
        educated, and empowered through collective efforts.
      </p>

      <a href="https://www.instagram.com/inamigosfoundation/"
         target="_blank"
         class="hero-btn">

         Join The Community

      </a>

    </div>

  </section>

  <!-- CONTACT -->

  <section id="contact">

    <div class="section-title">

      <h2>Connect With Us</h2>

      <p>
        Follow our journey and collaborate with us
      </p>

    </div>

    <div class="contact-grid">

      <div class="contact-card">

        <h3>Instagram</h3>

        <p>
          Explore campaigns and volunteer activities
        </p>

        <a href="https://www.instagram.com/inamigosfoundation/"
           target="_blank">

           @inamigosfoundation

        </a>

      </div>

      <div class="contact-card">

        <h3>LinkedIn</h3>

        <p>
          Connect professionally and discover opportunities
        </p>

        <a href="https://www.linkedin.com/"
           target="https://www.linkedin.com/company/inamigos-foundation/">

           Visit LinkedIn

        </a>

      </div>

      <div class="contact-card">

        <h3>Email</h3>

        <p>
          Reach out for volunteering or partnerships
        </p>

        <a href="mailto:inamigosfoundation@gmail.com">

          inamigosfoundation@gmail.com

        </a>

      </div>

    </div>

    <!-- FORM -->

    <div class="form-box">

      <h2>Send Us A Message</h2>

      <form>

        <input type="text" placeholder="Your Name" required>

        <input type="email" placeholder="Your Email" required>

        <textarea placeholder="Your Message"></textarea>

        <button type="submit">
          Send Message
        </button>

      </form>

    </div>

  </section>

  <!-- FOOTER -->

  <footer>

    <h2>#InAmigos</h2>

    <p>
      Empowering communities through awareness,
      volunteering, education, and impactful initiatives.
    </p>

    <br>

    <p>
      Follow us on
      <a href="https://www.instagram.com/inamigosfoundation/"
         target="_blank">

         Instagram

      </a>
    </p>

    <br>

    <p>
      © 2026 InAmigos NGO — Together We Create Change
    </p>

  </footer>

</body>
</html>
